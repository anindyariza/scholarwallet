{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferredCurrency": { "type": "string" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string", "enum": ["Cash", "Debit", "E-Wallet"] },
        "description": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "type", "category", "date", "paymentMethod"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Budget limit for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limitAmount": { "type": "number" },
        "monthYear": { "type": "string" }
      },
      "required": ["userId", "category", "limitAmount", "monthYear"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stores individual financial transactions"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Stores monthly budget limits per category"
    }
  }
}
